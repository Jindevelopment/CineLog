<%- include('../partials/header', { title: person.name }) %>

<div class="person-header">
  <div class="person-photo">
    <% if (person.profile) { %>
      <img src="https://image.tmdb.org/t/p/w342<%= person.profile %>" alt="<%= person.name %>">
    <% } else { %>
      <div class="no-photo-lg">👤</div>
    <% } %>
  </div>
  <div class="person-info">
    <h1><%= person.name %></h1>
    <div class="person-facts">
      <% if (person.department) { %><span class="person-tag"><%= person.department %></span><% } %>
      <% if (person.birthday) { %><span class="muted">🎂 <%= person.birthday %></span><% } %>
      <% if (person.place) { %><span class="muted">📍 <%= person.place %></span><% } %>
    </div>
    <% if (person.bio) { %>
      <p class="person-bio"><%= person.bio.length > 360 ? person.bio.slice(0, 360) + '…' : person.bio %></p>
    <% } %>
  </div>
</div>

<section class="section">
  <div class="section-header"><h2>🎬 출연작 <span class="muted" style="font-size:1rem">(<%= person.filmography.length %>)</span></h2></div>
  <% if (person.filmography.length === 0) { %>
    <p class="muted">출연작 정보가 없습니다.</p>
  <% } else { %>
    <div class="movie-grid">
      <% person.filmography.forEach(c => { %>
        <a href="/movies/<%= c.type %>/<%= c.id %>" class="movie-card">
          <img src="https://image.tmdb.org/t/p/w300<%= c.poster %>" alt="<%= c.title %>" class="movie-poster" loading="lazy">
          <div class="movie-info">
            <p class="movie-title"><%= c.title %></p>
            <% if (c.character) { %><p class="cast-role muted"><%= c.character %> 역</p><% } %>
            <div class="movie-meta">
              <% if (c.year) { %><span class="muted" style="font-size:0.8rem"><%= c.year %></span><% } %>
              <span class="type-badge <%= c.type === 'tv' ? 'badge-tv' : 'badge-movie' %>"><%= c.type === 'tv' ? 'TV' : '영화' %></span>
              <% if (c.rating && c.rating !== '0.0') { %><span class="muted" style="font-size:0.8rem">⭐ <%= c.rating %></span><% } %>
            </div>
          </div>
        </a>
      <% }) %>
    </div>
  <% } %>
</section>

<div class="actions">
  <a href="/reviews/search" class="btn">← 검색으로</a>
</div>

<%- include('../partials/footer') %>
